*.xlsx
*.xlsm
*.xls
!test/fixtures/**/*.xlsx
!test/fixtures/**/*.xlsm
!test/fixtures/**/*.xls

# Environment — never commit secrets
.env
.env.*
!.env.example
.deploy.env

