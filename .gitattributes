# Normalise line endings to LF in the repo; checkout as-is on all platforms.
* text=auto eol=lf

# Binary files — never diff or merge
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.xlsx  binary
*.xlsm  binary
*.xls   binary

# Lock files — keep as text but do not diff
package-lock.json   text eol=lf
