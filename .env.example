# # Copy to .env in the repo root (or export in your shell) for local development.

# # PostgreSQL (matches docker-compose.yml defaults)
# DATABASE_URL=postgresql://ses:ses@127.0.0.1:5432/ses

# # Redis — Socket.IO adapter / BullMQ when wired
# REDIS_URL=redis://127.0.0.1:6380

# # API auth cookie signing (change in any shared environment). If unset, dev uses
# # a built-in fallback. When set, the value must be ≥ 32 characters or the API
# # refuses to start (avoids accidentally deploying a weak secret).
# SES_AUTH_SECRET=ses-local-dev-placeholder-secret-change-me

# # Comma-separated browser origins for CORS (defaults to local Vite if unset)
# # SES_CORS_ORIGINS=http://127.0.0.1:3210,http://localhost:3210

# # Production: set SES_COOKIE_SECURE=true behind HTTPS. In NODE_ENV=production,
# # SES_AUTH_SECRET is required and must be at least 32 characters.

# # Cookie SameSite policy: lax (default), strict, or none (requires Secure)
# # SES_COOKIE_SAMESITE=strict

# # Never enable in production unless intentional:
# # SES_ALLOW_DEV_LOGIN=true

# # Outbound escalation sends (Issue #72). Without these, POST .../send returns 503.
# # SES_SMTP_URL=smtps://user:pass@smtp.example.com:465
# # SES_MAIL_FROM="SES <noreply@example.com>"
# # SES_TEAMS_INCOMING_WEBHOOK_URL=https://outlook.office.com/webhook/...

# # --- Frontend (@ses/web) — set in `apps/web/.env` or export before `vite build` ---
# # Tile dashboard + `/processes/...` URLs (default). Set to `false` for legacy-primary `/workspace/...` routing.
# # VITE_FEATURE_TILES_DASHBOARD=false
# # Per-tile Tracking (Kanban) tab in workspace (default off). Set to `true` for one release cycle of legacy behavior.
# # VITE_FEATURE_LEGACY_TILE_TRACKING_TAB=true
SES_BASE_URL=http://127.0.0.1:3210
SES_CORS_ORIGINS=http://127.0.0.1:3210
# Behind an HTTPS edge (Cloudflare tunnel / nginx TLS) this MUST be true.
SES_COOKIE_SECURE=false
SES_COOKIE_SAMESITE=lax
SES_ALLOW_DEV_LOGIN=false
SES_ALLOW_DEMO_DEV_LOGIN=false
# F1: placeholder ONLY — never commit a real secret. Generate per environment:
#   openssl rand -hex 32
# API refuses to start in production if this is unset or < 32 chars.
SES_AUTH_SECRET=replace-with-32-plus-random-bytes-openssl-rand-hex-32
# Dev Redis has no password (docker-compose.yml). Prod
# (docker-compose.prod.yml) requires REDIS_PASSWORD and the URL carries it:
#   REDIS_URL=redis://:<password>@redis:6379
REDIS_URL=redis://127.0.0.1:6380
# F18: prod only — Redis AUTH password. Fail-closed in docker-compose.prod.yml.
# REDIS_PASSWORD=replace-with-32-plus-random-bytes

# # AI Pilot + Analytics sidecar — FastAPI app at services/ai-sidecar/.
# # Wraps Ollama. Start with services/ai-sidecar/start-ai.sh.
AI_SERVICE_URL=http://localhost:8000
AI_PILOT_REQUEST_TIMEOUT_MS=60000
# F2: shared secret the API sends to the sidecar as X-Internal-Token. The
# sidecar refuses every non-health route (503) if its copy is unset, and
# rejects callers (401) without a matching token. Generate: openssl rand -hex 32
# Must be IDENTICAL on the API and the sidecar. Placeholder only — never commit.
SIDECAR_SHARED_SECRET=replace-with-32-plus-random-bytes-shared-with-sidecar
AI_PILOT_SANDBOX_TTL_HOURS=24

# Analytics agent — primary reasoner that emits SQL + ChartSpec.
AI_AGENT_MODEL=qwen2.5-coder:7b-instruct
# Lightweight router/enhancer (replaces llama3:latest in older deploys).
AI_ROUTER_MODEL=llama3.2:3b
# Embedding model for rule retrieval (Phase 4).
AI_EMBED_MODEL=nomic-embed-text

# Ollama parallelism. Each parallel slot = one full model copy in VRAM:
#   7B q4 model ≈ 5GB × 4 = ~20GB. Lower this to 1-2 on smaller boxes.
OLLAMA_NUM_PARALLEL=4

# Analytics chat cache. Event-driven eviction on version.saved is primary;
# this TTL is a fallback safety net.
ANALYTICS_CACHE_TTL_SECONDS=1800

# F11: ai_chat_audit retention window (days). A daily cron deletes audit
# rows (raw prompts / generated SQL / answers) older than this.
ANALYTICS_AUDIT_RETENTION_DAYS=90

# ── Object storage (S3-compatible) ─────────────────────────────────────────
# Uploaded PDFs/sample files land here; Postgres only keeps metadata.
# The same code targets MinIO and AWS S3 — switch by changing env vars only.
#
# Local dev defaults ONLY (matches docker-compose.yml dev MinIO). F5: prod
# (docker-compose.prod.yml) refuses to start unless real values are supplied
# via .deploy.env — these minioadmin values must never reach a shared env.
OBJECT_STORAGE_DRIVER=s3
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# Per-purpose buckets — each upload kind has its own bucket so retention
# and IAM scope can differ per data type.
OBJECT_STORAGE_BUCKET_WORKBOOKS=ses-workbooks
OBJECT_STORAGE_BUCKET_AI_PILOT=ses-ai-files
OBJECT_STORAGE_BUCKET_PDFS=ses-ai-pdfs

# Legacy single-bucket fallback (only used if a per-purpose var above
# is unset). Kept for backwards-compat with older configs.
OBJECT_STORAGE_BUCKET=ses-ai-files

# Optional — pre-signed URL TTL in seconds (default 900).
# OBJECT_STORAGE_PRESIGN_TTL_SECONDS=900

# Production AWS S3 example (uncomment, leave ENDPOINT empty):
# OBJECT_STORAGE_DRIVER=s3
# OBJECT_STORAGE_ENDPOINT=
# OBJECT_STORAGE_REGION=ap-south-1
# OBJECT_STORAGE_BUCKET_WORKBOOKS=your-prod-workbooks
# OBJECT_STORAGE_BUCKET_AI_PILOT=your-prod-ai-pilot
# OBJECT_STORAGE_BUCKET_PDFS=your-prod-ai-pdfs
# OBJECT_STORAGE_ACCESS_KEY=your-aws-access-key
# OBJECT_STORAGE_SECRET_KEY=your-aws-secret-key
# OBJECT_STORAGE_FORCE_PATH_STYLE=false
