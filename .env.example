# Copy this file to .env in the repo root for local development.
#   cp .env.example .env
#
# Do NOT commit .env — it is git-ignored.
# All variables are optional unless marked REQUIRED.

# ── Database (matches docker-compose.yml defaults) ───────────────────────────
DATABASE_URL=postgresql://ses:ses@127.0.0.1:5432/ses

# ── Redis — Socket.IO fan-out ─────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6380

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED in any shared/production environment (≥ 32 chars).
# In local dev, a built-in fallback is used when unset.
SES_AUTH_SECRET=ses-local-dev-placeholder-secret-change-me

# Cookie settings (safe defaults for local HTTP)
SES_COOKIE_SECURE=false
SES_COOKIE_SAMESITE=lax

# Password-less login for local/demo ONLY.
# Automatically rejected when NODE_ENV=production.
SES_ALLOW_DEV_LOGIN=false
SES_ALLOW_DEMO_DEV_LOGIN=false

# ── API bind + CORS ───────────────────────────────────────────────────────────
# Defaults: HOST=127.0.0.1, PORT=3211
# HOST=0.0.0.0
# PORT=3211

# Comma-separated allowed browser origins (defaults to localhost:3210 when unset)
# SES_CORS_ORIGINS=http://localhost:3210,http://127.0.0.1:3210

# Public base URL used to build absolute links in responses
# SES_BASE_URL=http://localhost:3210

# ── Notification delivery ─────────────────────────────────────────────────────
# SES uses a client-side handoff model — no SMTP server or Teams webhook needed.
# When the user clicks Send, the app opens their own Outlook (mailto:) or
# Microsoft Teams (deep-link) with the prefilled message. The API records the
# handoff and advances the escalation stage; actual sending happens in the
# user's own mail/Teams client.
#
# SLA follow-up cron interval (default: 15 minutes)
# SLA_ENFORCER_INTERVAL_MINUTES=15

# ── AI Pilot ──────────────────────────────────────────────────────────────────
# The AI Pilot is a separate FastAPI service wrapping a local LLM (Ollama).
# Start everything with: ./dev.sh ai
#
# FastAPI service URL
AI_SERVICE_URL=http://localhost:8000

# Request timeout for AI generation calls (milliseconds)
AI_PILOT_REQUEST_TIMEOUT_MS=60000

# Sandbox session TTL (hours)
AI_PILOT_SANDBOX_TTL_HOURS=24

# Ollama model (must be pulled: ollama pull qwen2.5:7b)
# AI_MODEL=qwen2.5:7b

# Ollama base URL (default: http://localhost:11434)
# OLLAMA_URL=http://localhost:11434

# ── LAN dev access (optional) ─────────────────────────────────────────────────
# Your machine's LAN IP — lets you test from a phone/tablet on the same network.
# dev.sh uses this to configure CORS and print the LAN URL on startup.
# DEV_HOST_IP=192.168.1.100

# ── Frontend feature flags ────────────────────────────────────────────────────
# Set in apps/web/.env or export before `vite build`.
# VITE_FEATURE_TILES_DASHBOARD=true
# VITE_FEATURE_LEGACY_TILE_TRACKING_TAB=false
