{
  "name": "@ses/api",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/main.js",
    "start:dev": "ts-node --transpile-only src/main.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "tsx db/runner.ts",
    "db:migrate:dryrun": "tsx db/runner.ts --dry-run",
    "db:baseline": "tsx db/runner.ts --baseline --confirm-baseline",
    "db:seed": "tsx db/seed.ts",
    "test": "tsx --test test/*.test.ts",
    "test:e2e": "NODE_ENV=test TS_NODE_TRANSPILE_ONLY=false node --require ts-node/register --test test/files.e2e-spec.ts test/directory.e2e-spec.ts test/auth.e2e-spec.ts test/process-scope-rbac.e2e-spec.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/lib-storage": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@grpc/grpc-js": "^1.12.5",
    "@grpc/proto-loader": "^0.7.13",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.19",
    "@ses/domain": "file:../../packages/domain",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.6.1",
    "exceljs": "4.4.0",
    "file-type": "^21.3.4",
    "fuzzball": "^2.2.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "ulid": "^3.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.6.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
